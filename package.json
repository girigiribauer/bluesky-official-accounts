{
  "name": "bluesky-official-accounts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 15010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "fetch": "tsx scripts/fetchAccountList.ts && tsx scripts/fetchNewsList.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:generate-types": "supabase gen types typescript --local 2>/dev/null > src/types/database.ts",
    "test": "npm run db:generate-types && vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run db:generate-types && vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@atproto/oauth-client-node": "^0.3.17",
    "@notionhq/client": "^2.2.15",
    "@vercel/analytics": "^1.4.1",
    "next": "^16.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.12.3",
    "sass": "^1.77.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "supabase": "^2.84.4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vercel": "^32.3.0",
    "vitest": "^4.1.0"
  }
}
